---
import Base from '../layouts/Base.astro';
---
<Base
  title="Formations – CDSBF77"
  description="Formations d'encadrants et d'officiels de savate en Seine-et-Marne : moniteurs, juges et arbitres."
>
  <section class="page-hero">
    <p class="kicker">Formations</p>
    <h1>Encadrer, juger, arbitrer</h1>
  </section>
  <main class="main-content">
    <div class="container">
      <section class="card visible">
        <div class="card-content">
          <h2 class="section-title">Devenir moniteur ou officiel</h2>
          <p>
            Le comité relaie et organise les formations fédérales : monitorat de savate,
            formations de juges et d'arbitres, recyclages et accompagnement des clubs.
            Les dates de sessions seront publiées sur cette page.
          </p>
          <p>Une question sur un cursus ? <a href="/contact">Contactez le comité</a>.</p>
        </div>
      </section>
    </div>
  </main>
</Base>
