---
import Base from '../layouts/Base.astro';
---
<Base
  title="Contact – CDSBF77"
  description="Contacter le Comité Départemental de Savate Boxe Française de Seine-et-Marne."
>
  <section class="page-hero">
    <p class="kicker">Contact</p>
    <h1>Écrire au comité</h1>
  </section>
  <main class="main-content">
    <div class="container">
      <section class="card visible">
        <div class="card-content">
          <div class="info-grid">
            <div class="info-card">
              <h3><i class="fas fa-map-marker-alt"></i>Adresse</h3>
              <p>Comité Départemental de Savate Boxe Française de Seine-et-Marne<br />
              24 avenue Franklin Roosevelt<br />77100 Meaux</p>
            </div>
            <div class="info-card">
              <h3><i class="fas fa-envelope"></i>Email &amp; téléphone</h3>
              <p><a href="mailto:contact@cdsbf77.org">contact@cdsbf77.org</a></p>
              <p><a href="tel:0626498259">06 26 49 82 59</a></p>
            </div>
            <div class="info-card">
              <h3><i class="fas fa-share-alt"></i>Réseaux</h3>
              <p><a href="https://www.instagram.com/comite_77_savate_bf/" rel="noopener"><i class="fab fa-instagram"></i> Instagram</a></p>
              <p><a href="https://www.facebook.com/profile.php?id=100088440284322" rel="noopener"><i class="fab fa-facebook-f"></i> Facebook</a></p>
            </div>
          </div>
          <p style="margin-top:1.5rem;">Pour rejoindre un club, consultez directement <a href="/clubs">l'annuaire</a> : chaque fiche indique le contact du club.</p>
        </div>
      </section>
    </div>
  </main>
</Base>
