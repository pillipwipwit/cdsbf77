---
import Base from '../../layouts/Base.astro';
const disciplines = [
  { icone: 'fa-fist-raised', nom: 'Savate boxe française', texte: "Sport de combat né en France au XIXe siècle : on touche avec les pieds chaussés et les poings gantés. Deux formes de pratique : l'assaut, où seule la touche compte, et le combat, réservé aux tireurs confirmés." },
  { icone: 'fa-walking', nom: 'Canne de combat', texte: "L'escrime française à la canne de châtaignier : vitesse, précision et élégance. Une discipline patrimoniale spectaculaire, accessible dès le plus jeune âge." },
  { icone: 'fa-heartbeat', nom: 'Savate forme', texte: "Le fitness version savate : des enchaînements pieds-poings en musique, sans opposition. Cardio, renforcement et technique, sans toucher ni être touché." },
  { icone: 'fa-shield-alt', nom: 'Savate défense', texte: "La déclinaison self-défense de la savate : apprendre à se protéger avec des techniques simples et efficaces, dans un cadre réglementé et progressif." },
];
---
<Base
  title="Les disciplines – CDSBF77"
  description="Savate boxe française, canne de combat, savate forme et savate défense : quatre disciplines enseignées dans les clubs de Seine-et-Marne."
>
  <section class="page-hero">
    <p class="kicker">Disciplines</p>
    <h1>Quatre façons de pratiquer</h1>
  </section>
  <main class="main-content">
    <div class="container">
      <div class="features-grid">
        {disciplines.map((d) => (
          <div class="feature-card">
            <div class="feature-icon"><i class={'fas ' + d.icone}></i></div>
            <h3 class="feature-title">{d.nom}</h3>
            <p class="feature-description">{d.texte}</p>
          </div>
        ))}
      </div>
      <p style="text-align:center; margin-top:2.5rem;">
        <a class="btn-or" href="/clubs">Trouver un club qui enseigne ces disciplines</a>
      </p>
    </div>
  </main>
</Base>
