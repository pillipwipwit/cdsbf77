---
import Base from '../layouts/Base.astro';
---
<Base
  title="Liens utiles – CDSBF77"
  description="Les liens utiles de la savate en Seine-et-Marne : fédération, ligue Île-de-France et département."
>
  <section class="page-hero">
    <p class="kicker">Ressources</p>
    <h1>Liens utiles</h1>
  </section>
  <main class="main-content">
    <div class="container">
      <div class="info-grid">
        <div class="info-card">
          <h3><i class="fas fa-flag"></i>Fédération</h3>
          <p><a href="https://www.ffsavate.com" rel="noopener">Fédération Française de Savate</a></p>
        </div>
        <div class="info-card">
          <h3><i class="fas fa-map"></i>Ligue</h3>
          <p><a href="https://liguesavateidf.fr/" rel="noopener">Ligue de Savate d'Île-de-France</a></p>
        </div>
        <div class="info-card">
          <h3><i class="fas fa-landmark"></i>Département</h3>
          <p><a href="https://seine-et-marne.fr/fr" rel="noopener">Département de Seine-et-Marne</a></p>
        </div>
      </div>
    </div>
  </main>
</Base>
