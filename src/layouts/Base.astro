---
import '../styles/comite.css';
import { ClientRouter } from 'astro:transitions';

const {
  title = 'CDSBF77 – Savate boxe française en Seine-et-Marne',
  description = 'Le Comité Départemental de Savate Boxe Française de Seine-et-Marne : annuaire des clubs, disciplines, compétitions et formations.',
  jsonLd = null,
} = Astro.props;

const urlCanonique = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = 'https://i.postimg.cc/zfhFq0j9/logocdsbf.jpg';

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SportsOrganization',
  name: 'Comité Départemental de Savate Boxe Française de Seine-et-Marne',
  alternateName: 'CDSBF77',
  sport: 'Savate boxe française',
  url: 'https://www.cdsbf77.org',
  logo: ogImage,
  email: 'cdsbf77@gmail.com',
  telephone: '+33626498259',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Maison des Sports, 12 B rue du Président Despatys',
    postalCode: '77000',
    addressLocality: 'Melun',
    addressCountry: 'FR',
  },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Seine-et-Marne',
  },
  parentOrganization: {
    '@type': 'SportsOrganization',
    name: 'Fédération Française de Savate Boxe Française et Disciplines Associées',
    url: 'https://www.ffsavate.com',
  },
  sameAs: [
    'https://www.facebook.com/profile.php?id=100088440284322',
    'https://www.instagram.com/comite_77_savate_bf/',
  ],
};

const nav = [
  { href: '/', label: 'Accueil' },
  { href: '/clubs', label: 'Clubs' },
  { href: '/disciplines', label: 'Disciplines' },
  { href: '/competitions', label: 'Compétitions' },
  { href: '/formations', label: 'Formations' },
  { href: '/developpement', label: 'Développement' },
  { href: '/actualites', label: 'Actualités' },
  { href: '/contact', label: 'Contact' },
];
const chemin = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:site_name" content="CDSBF77" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={urlCanonique} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="fr_FR" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Bebas+Neue&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <noscript><style>.card { opacity: 1 !important; transform: none !important; }
      .anim-cascade > * { opacity: 1 !important; transform: none !important; }</style></noscript>
    <ClientRouter />
  </head>
  <body>
    <div class="particles" id="particles" aria-hidden="true"></div>

    <nav class="navigation" id="navigation" aria-label="Navigation principale">
      <div class="nav-container">
        {nav.map((item) => (
          <a
            href={item.href}
            class="nav-link"
            aria-current={chemin === item.href || (item.href !== '/' && chemin.startsWith(item.href + '/')) ? 'page' : undefined}
          ><span>{item.label}</span></a>
        ))}
      </div>
    </nav>

    <slot />

    <footer id="contact">
      <div class="footer-content">
        <img src="https://i.postimg.cc/zfhFq0j9/logocdsbf.jpg" alt="Logo CDSBF77" class="footer-logo" loading="lazy" />
        <div class="social-links">
          <a href="https://www.facebook.com/profile.php?id=100088440284322" class="social-link" aria-label="Facebook" rel="noopener">
            <i class="fab fa-facebook-f"></i>
          </a>
          <a href="https://www.instagram.com/comite_77_savate_bf/" class="social-link" aria-label="Instagram" rel="noopener">
            <i class="fab fa-instagram"></i>
          </a>
          <a href="mailto:cdsbf77@gmail.com" class="social-link" aria-label="Email">
            <i class="fas fa-envelope"></i>
          </a>
        </div>
        <p>© 2026 - Comité Départemental de Savate Boxe Française de Seine-et-Marne</p>
        <p>
          <a href="mailto:cdsbf77@gmail.com" style="color: var(--gold); text-decoration: none;">cdsbf77@gmail.com</a>
          &nbsp;·&nbsp;
          <a href="/liens" style="color: var(--gold); text-decoration: none;">Liens utiles</a>
          &nbsp;·&nbsp;
          <a href="/comite" style="color: var(--gold); text-decoration: none;">Le comité</a>
          &nbsp;·&nbsp;
          <a href="/mentions-legales" style="color: var(--gold); text-decoration: none;">Mentions légales</a>
        </p>
      </div>
    </footer>

    <script>
      const sobre = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const tactile = () => window.matchMedia('(hover: none), (pointer: coarse)').matches;

      // Barre de navigation : posée une seule fois, l'élément est requestionné à chaque appel
      window.addEventListener('scroll', () => {
        const nav = document.getElementById('navigation');
        if (nav) nav.classList.toggle('scrolled', window.pageYOffset > 100);
      }, { passive: true });

      function particules() {
        const conteneur = document.getElementById('particles');
        if (!conteneur || sobre() || conteneur.childElementCount > 0) return;
        for (let i = 0; i < 20; i++) {
          const p = document.createElement('div');
          p.className = 'particle';
          p.style.left = Math.random() * 100 + '%';
          p.style.animationDelay = Math.random() * 20 + 's';
          p.style.animationDuration = (15 + Math.random() * 20) + 's';
          const taille = Math.random() * 5 + 3;
          p.style.width = taille + 'px';
          p.style.height = taille + 'px';
          conteneur.appendChild(p);
        }
      }

      function apparitions() {
        // Cartes pleine largeur
        const obsCartes = new IntersectionObserver((entrees) => {
          entrees.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('visible'); obsCartes.unobserve(e.target); } });
        }, { threshold: 0.1, rootMargin: '0px 0px -100px 0px' });
        document.querySelectorAll('.card').forEach((c) => obsCartes.observe(c));

        // Grilles : apparition en cascade, un enfant après l'autre
        const grilles = document.querySelectorAll('.features-grid, .info-grid, .clubs-grid, .club-galerie');
        const obsGrilles = new IntersectionObserver((entrees) => {
          entrees.forEach((e) => {
            if (!e.isIntersecting) return;
            Array.from(e.target.children).forEach((enfant) => enfant.classList.add('revele'));
            obsGrilles.unobserve(e.target);
          });
        }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });
        grilles.forEach((g) => {
          g.classList.add('anim-cascade');
          Array.from(g.children).forEach((enfant, i) => enfant.style.setProperty('--i', String(i)));
          obsGrilles.observe(g);
        });
      }

      function inclinaison3d() {
        if (sobre() || tactile()) return;
        const cartes = document.querySelectorAll('.feature-card, .club-card, .info-card, .partner-item');
        const AMPLITUDE = 7;   // degrés maximum
        const ELEVATION = 10;  // pixels de soulèvement
        cartes.forEach((carte) => {
          carte.classList.add('carte-3d');
          let trame = null;
          carte.addEventListener('pointermove', (ev) => {
            if (trame) return;
            trame = requestAnimationFrame(() => {
              trame = null;
              const r = carte.getBoundingClientRect();
              const x = (ev.clientX - r.left) / r.width - 0.5;
              const y = (ev.clientY - r.top) / r.height - 0.5;
              carte.classList.add('incline');
              carte.style.transform =
                'perspective(1100px) rotateX(' + (-y * AMPLITUDE * 2).toFixed(2) + 'deg)' +
                ' rotateY(' + (x * AMPLITUDE * 2).toFixed(2) + 'deg)' +
                ' translateY(-' + ELEVATION + 'px) scale(1.02)';
            });
          });
          carte.addEventListener('pointerleave', () => {
            if (trame) { cancelAnimationFrame(trame); trame = null; }
            carte.classList.remove('incline');
            carte.style.transform = '';
          });
        });
      }

      function logoClub() {
        if (sobre() || tactile()) return;
        const bandeau = document.querySelector('.club-scope .page-hero');
        const bloc = document.querySelector('.club-logo-bloc');
        if (!bandeau || !bloc) return;
        let trame = null;
        bandeau.addEventListener('pointermove', (ev) => {
          if (trame) return;
          trame = requestAnimationFrame(() => {
            trame = null;
            const r = bandeau.getBoundingClientRect();
            const x = (ev.clientX - r.left) / r.width - 0.5;
            const y = (ev.clientY - r.top) / r.height - 0.5;
            bloc.style.transform =
              'perspective(900px) rotateX(' + (-y * 12).toFixed(2) + 'deg) rotateY(' + (x * 12).toFixed(2) + 'deg)';
          });
        });
        bandeau.addEventListener('pointerleave', () => {
          if (trame) { cancelAnimationFrame(trame); trame = null; }
          bloc.style.transition = 'transform 0.6s cubic-bezier(0.22, 1.4, 0.36, 1)';
          bloc.style.transform = '';
          setTimeout(() => { bloc.style.transition = ''; }, 650);
        });
      }

      function annee() {
        const a = new Date().getFullYear();
        document.querySelectorAll('footer p').forEach((p) => {
          if (p.textContent.includes('©')) p.textContent = p.textContent.replace('2026', String(a));
        });
      }

      function initialiser() {
        particules();
        apparitions();
        inclinaison3d();
        logoClub();
        annee();
      }

      // Se déclenche au premier chargement comme après chaque transition de page
      document.addEventListener('astro:page-load', initialiser);
    </script>
  </body>
</html>
